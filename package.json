{
  "name": "docker+webdriverio",
  "type": "module",
  "devDependencies": {
    "@wdio/allure-reporter": "^9.29.1",
    "@wdio/cli": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1"
  },
  "scripts": {
    "wdio": "wdio run ./wdio.conf.js",
    "report-generate": "allure generate ./allure-results --clean -o ./allure-report",
    "report-open":"allure open ./allure-report",
    "test":"npm run wdio && npm run report-generate && npm run report-open"
  }
}
