{
  "name": "docker+webdriverio",
  "type": "module",
  "devDependencies": {
    "@wdio/allure-reporter": "^9.29.1",
    "@wdio/cli": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^7.7.3",
    "@wdio/spec-reporter": "^9.29.1",
    "start-server-and-test": "^3.0.11",
    "wdio-docker-service": "^3.2.1"
  },
  "scripts": {
    "app:start":"cd ./hub-de-leitura-integrado/ && npm run start",
    "ci:test": "start-server-and-test app:start http://localhost:3000 test",
    "wdio": "wdio run ./wdio.conf.js",
    "report-generate": "allure generate ./allure-results --clean -o ./allure-report",
    "test": "npm run wdio && npm run report-generate"
  }
}
